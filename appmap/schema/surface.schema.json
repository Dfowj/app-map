{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://app-map/surface.schema.json",
  "title": "Surface record frontmatter",
  "description": "Frontmatter for surfaces/<id>/surface.md. Tier comments mark ownership: tier-1 script-owned, tier-2 agent-asserted, tier-3 human-authored (preserved on recompute). Validation here is intentionally lenient (warn, record, never block).",
  "type": "object",
  "required": ["id", "title", "kind"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "description": "TIER-3 (manual): immutable slug, set once at creation, never changes.",
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "title": { "description": "TIER-2", "type": "string" },
    "kind": {
      "description": "TIER-2",
      "type": "string",
      "enum": ["screen", "tab-root", "tab-bar", "sheet", "modal", "popover", "container"]
    },
    "code_anchor": {
      "description": "TIER-2 (mutable). Hook/validator flags if file or symbol vanishes.",
      "type": "object",
      "required": ["file"],
      "properties": {
        "file": { "type": "string" },
        "symbol": { "type": "string" }
      }
    },
    "contains": {
      "description": "TIER-2. Structural nesting (tab-bar contains its tab roots). NOT navigation edges.",
      "type": "array",
      "items": { "type": "string" }
    },
    "edges": {
      "description": "TIER-2 shape / TIER-3 note. OUTGOING navigation only; incoming is derived at render.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "to"],
        "properties": {
          "id": { "description": "Stable key; required because `to` is not unique. Stable once a note is attached.", "type": "string" },
          "to": { "type": "string" },
          "via": { "type": "string", "enum": ["push", "present", "tab-switch", "deep-link"] },
          "presentation": { "type": "string", "enum": ["sheet", "modal", "popover", "fullScreen"] },
          "trigger": { "type": "string" },
          "note": { "description": "TIER-3 (preserved on merge).", "type": "string" }
        }
      }
    },
    "entry_points": {
      "description": "TIER-2 shape / TIER-3 note. Ways in from OUTSIDE the app graph. Keyed by type+value.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "enum": ["deepLink", "pushNotification", "widget", "siri", "universalLink", "shortcut"] },
          "value": { "type": "string" },
          "to": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "states": {
      "description": "TIER-2 shape / TIER-3 note. Variants of THIS surface. Keyed by name.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "screenshot": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "dependencies": {
      "description": "TIER-2 shape / TIER-3 note.",
      "type": "object",
      "properties": {
        "external": {
          "description": "Notable external only — not internal packages.",
          "type": "array",
          "items": { "type": "string" }
        },
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "type": { "type": "string", "enum": ["model", "fetch", "api", "store", "cache"] },
              "name": { "type": "string" },
              "note": { "type": "string" }
            }
          }
        }
      }
    },
    "last_verified": {
      "description": "TIER-1 (mechanical). Stamped by script on record change.",
      "type": "object",
      "properties": {
        "sha": { "type": "string" },
        "date": { "type": "string" }
      }
    },
    "needs_review": {
      "description": "TIER-1 (mechanical). Set by drift detection; cleared by agent/human.",
      "type": "boolean"
    }
  }
}
